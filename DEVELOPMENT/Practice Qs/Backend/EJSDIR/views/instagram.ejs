<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instagram</title>
</head>
<body style="background-color: black;color: whitesmoke;">
    <h2>This page belongs to <%= data.name %></h2>
    <button>Follow</button>
    <button>Message</button>
    <h1>Numbers of accounts that follow you :<%= data.followers %></h1>
    <h1>Numbers of accounts that you are following :<%= data.following %></h1>
    <hr>
    <h1>Posts</h1>
    <% for (let post of data.posts){ %>
        <div>
            <img src="<%=post.image%>" alt="Post Image" style="width: 300px;">
            <p>Post</p>
            <p>likes:<%=post.likes %></p>
            <p>Comments:<%=post.comments %></p>
        </div>
    <%}%>
</body>
</html>
