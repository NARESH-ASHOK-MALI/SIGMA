<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Your Chat</title>
</head>
<body>
    <h1>Edit Your Chat:<%=chat.id%></h1>
    <h1>This chat was sent from: <b><%=chat.from%></b> to: <b><%=chat.To%></b></h1>
    <form method="POST" action="/chats/<%=chat._id%>?_method=PUT">
        <textarea name="msg" rows="6" cols="50"><%=chat.msg%></textarea>
        <button>Edit</button>
    </form>
</body>
</html>