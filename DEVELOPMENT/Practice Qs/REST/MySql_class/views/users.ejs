<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All users</title>
    <style>
        table, th, td {
            border: 1px solid black;
        }
        th, td {
            padding: 10px;
        }
    </style>
</head>
<body>
     <form method="GET" action="/user/new">
      <button>Add New User</button>
    </form>
    <table>
        <tr>
            <th>ID</th>
            <th>Email</th>
            <th>Username</th>
        </tr>
        <% for (let user of users) { %>
        <tr>
            <td><%= user.id %></td>
            <td><%= user.email %></td>
            <td><%= user.userName %></td> 
            <td><form action="/users/<%=user.id%>/edit">
                <button>Edit</button>
            </form></td>  
            <td><form method="get" action="/user/<%=user.id%>/delete">
                <button>Delete</button>
            </form></td>  
        </tr>
        <% } %>
    </table>
</body>
</html>